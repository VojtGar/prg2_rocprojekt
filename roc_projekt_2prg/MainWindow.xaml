<Window x:Class="roc_projekt_2prg.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:roc_projekt_2prg"
        mc:Ignorable="d"
        Title="Cesta do Morie" Height="1080" Width="1920" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SkryteTlacitko" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas x:Name="ScenaUvod" Visibility="Visible">
            <Image Source="/Images/startmenu.png" Stretch="Fill" Width="1920" Height="1080"/>
            <Button x:Name="BtnStart" Content="START HRY" FontSize="60" FontWeight="Bold" FontFamily="/Images/#Aniron" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="524" Height="81" Canvas.Left="698" Canvas.Top="403" Click="BtnStart_Click"/>
            <Button x:Name="BtnEnd" Content="KONEC" FontSize="60" FontWeight="Bold" FontFamily="/Images/#Aniron" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="442" Height="86" Canvas.Left="739" Canvas.Top="593" Click="BtnEnd_Click"/>
        </Canvas>


        <Canvas x:Name="ScenaTabor" Visibility="Collapsed">
            <Image Source="/Images/tabor.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="TÁBOR" FontSize="70" Foreground="White" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="/Images/#Aniron"/>


            <Button x:Name="BtnTruhla" Style="{StaticResource SkryteTlacitko}" Width="250" Height="90" Canvas.Left="1307" Canvas.Top="727" Click="BtnTruhla_Click"/>

            <Button x:Name="BtnOhen" Style="{StaticResource SkryteTlacitko}" Width="220" Height="180" Canvas.Left="552" Canvas.Top="637" Click="BtnOhen_Click"/>

            <Button Style="{StaticResource SkryteTlacitko}" Width="160" Height="317" Canvas.Left="5" Canvas.Top="500" Click="NavTaborDoLesa_Click" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button Style="{StaticResource SkryteTlacitko}" Width="300" Height="186" Canvas.Left="215" Canvas.Top="312" Click="NavTaborDoJeskyne_Click"/>
            <Button Style="{StaticResource SkryteTlacitko}" Width="232" Height="144" Canvas.Left="1458" Canvas.Top="333" Click="NavTaborDoMorie_Click"/>

            <Border Background="#CC000000" CornerRadius="15" Width="1200" Height="120" Canvas.Left="360" Canvas.Top="200" Padding="20">
                <TextBlock x:Name="TxtTaborVypis" Text="Jsi v táboře. Kolem plápolá oheň a tvůj úkol je dostat se do Morie." FontSize="28" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Canvas>

        <Canvas x:Name="ScenaLes" Visibility="Collapsed">
            <Image Source="/Images/les.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="HLUBOKÝ LES" FontSize="70" Foreground="LightGreen" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="/Images/#Aniron"/>

            <Button x:Name="BtnStrom" Style="{StaticResource SkryteTlacitko}" Width="135" Height="162" Canvas.Left="140" Canvas.Top="330" Click="BtnStrom_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button x:Name="BtnKer" Style="{StaticResource SkryteTlacitko}" Width="216" Height="124" Canvas.Left="1204" Canvas.Top="558" Click="BtnKer_Click" RenderTransformOrigin="0.447,0.84" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Button Style="{StaticResource SkryteTlacitko}" Width="300" Height="88" Canvas.Left="755" Canvas.Top="976" Click="NavLesDoTabora_Click" RenderTransformOrigin="0.483,0.538" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button Style="{StaticResource SkryteTlacitko}" Width="250" Height="156" Canvas.Left="1539" Canvas.Top="354" Click="NavLesDoReky_Click"/>

            <Border Background="#CC000000" CornerRadius="15" Width="1200" Height="120" Canvas.Left="360" Canvas.Top="200" Padding="20">
                <TextBlock x:Name="TxtLesVypis" Text="Vstoupil jsi do hlubokého a tichého lesa." FontSize="28" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Canvas>

        <Canvas x:Name="ScenaJeskyne" Visibility="Collapsed">
            <Image Source="/Images/jeskyne.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="TEMNÁ JESKYNĚ" FontSize="70" Foreground="LightGray" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="/Images/#Aniron"/>

            <Button x:Name="BtnJezkyneTma" Style="{StaticResource SkryteTlacitko}" Width="282" Height="142" Canvas.Left="1246" Canvas.Top="558" Click="BtnJeskyneTma_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button Style="{StaticResource SkryteTlacitko}" Width="686" Height="90" Canvas.Left="308" Canvas.Top="974" Click="NavJeskyneDoTabora_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Border Background="#CC000000" CornerRadius="15" Width="1200" Height="120" Canvas.Left="360" Canvas.Top="200" Padding="20">
                <TextBlock x:Name="TxtJeskyneVypis" Text="Uvnitř jeskyně svítí tvá zapálená louč. Zahání okolní temnotu." FontSize="28" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Canvas>

        <Canvas x:Name="ScenaReka" Visibility="Collapsed">
            <Image Source="/Images/jezero.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="DIVOKÉ JEZERO" FontSize="70" Foreground="LightBlue" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="/Images/#Aniron"/>

            <Button x:Name="BtnVetev" Style="{StaticResource SkryteTlacitko}" Width="250" Height="100" Canvas.Left="25" Canvas.Top="800" Click="BtnVetev_Click"/>
            <Button x:Name="BtnRekaTrpyt" Style="{StaticResource SkryteTlacitko}" Width="210" Height="100" Canvas.Left="750" Canvas.Top="540" Click="BtnRekaTrpyt_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Button Style="{StaticResource SkryteTlacitko}" Width="670" Height="82" Canvas.Left="601" Canvas.Top="998" Click="NavRekaDoLesa_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Border Background="#CC000000" CornerRadius="15" Width="1200" Height="120" Canvas.Left="360" Canvas.Top="200" Padding="20">
                <TextBlock x:Name="TxtRekaVypis" Text="Došel jsi k břehu dravého jezera. Na zemi leží naplavené dříví a hluboko ve vodě se něco blyští." FontSize="28" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Canvas>

        <Canvas x:Name="ScenaMoria" Visibility="Collapsed">
            <Image Source="/Images/dvere.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="DVEŘE DO MORIE" FontSize="70" Foreground="Gold" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="/Images/#Aniron"/>

            <Button x:Name="BtnMoriaDvere" Style="{StaticResource SkryteTlacitko}" Width="400" Height="400" Canvas.Left="784" Canvas.Top="284" Click="BtnMoriaDvere_Click"/>
            <Button Style="{StaticResource SkryteTlacitko}" Width="860" Height="86" Canvas.Left="276" Canvas.Top="978" Click="NavMoriaDoTabora_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Border Background="#CC000000" CornerRadius="15" Width="1200" Height="120" Canvas.Left="360" Canvas.Top="200" Padding="20">
                <TextBlock x:Name="TxtMoriaVypis" Text="Stojíš před legendární západní bránou Morie. Elfské nápisy vyžadují heslo pro vstup." FontSize="28" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Canvas>
    </Grid>
</Window>