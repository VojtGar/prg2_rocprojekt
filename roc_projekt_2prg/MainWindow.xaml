<Window x:Class="roc_projekt_2prg.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="1080" Width="1920">
    <Grid>
        <Canvas x:Name="ScenaLes" Visibility="Visible">
            <Image Source="pack://application:,,,/Images/les.png" Stretch="Fill" Width="1920" Height="1080"/>
            <TextBlock Text="HLUBOKÝ LES" FontSize="70" Foreground="LightGreen" FontWeight="Bold" Canvas.Left="100" Canvas.Top="80" FontFamily="pack://application:,,,/Images/#Aniron"/>

            <Button x:Name="BtnStrom" Content="Prohledat Strom" FontSize="30" Foreground="White" Background="#553311" Width="300" Height="80" Canvas.Left="500" Canvas.Top="450"/>
            <Button x:Name="BtnKer" Content="Prohledat Keř" FontSize="30" Foreground="White" Background="#114411" Width="300" Height="80" Canvas.Left="1120" Canvas.Top="450"/>

            <!-- NAVIGACE Z LESA -->
            <Button Content="Zpět do Tábora" FontSize="35" Foreground="White" Background="#444" Width="350" Height="80" Canvas.Left="100" Canvas.Top="850" Click="NavLesDoTabora_Click"/>
            <Button Content="-> Pokračovat k Řece" FontSize="35" Foreground="White" Background="#114466" Width="400" Height="80" Canvas.Left="1420" Canvas.Top="850" Click="NavLesDoReky_Click"/>
        </Canvas>
    </Grid>
</Window>